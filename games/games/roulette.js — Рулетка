const crypto = require('crypto');

const RED = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];

function spin(bet, betType, betValue) {
  const number = crypto.randomInt(0, 37); // 0-36
  const isRed = RED.includes(number);
  const isBlack = number !== 0 && !isRed;
  let win = 0;

  switch (betType) {
    case 'number': // x36
      if (number === parseInt(betValue)) win = bet * 36;
      break;
    case 'red':
      if (isRed) win = bet * 2;
      break;
    case 'black':
      if (isBlack) win = bet * 2;
      break;
    case 'even':
      if (number !== 0 && number % 2 === 0) win = bet * 2;
      break;
    case 'odd':
      if (number % 2 === 1) win = bet * 2;
      break;
    case 'low': // 1-18
      if (number >= 1 && number <= 18) win = bet * 2;
      break;
    case 'high': // 19-36
      if (number >= 19 && number <= 36) win = bet * 2;
      break;
  }

  return { number, color: number === 0 ? 'green' : (isRed ? 'red' : 'black'), win };
}

module.exports = { spin };
